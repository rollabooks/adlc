@startuml 08-oauth-mobile
!theme plain
skinparam backgroundColor white
skinparam defaultFontSize 11
skinparam SequenceMessageAlignment center
skinparam ParticipantBackgroundColor #F5F5F5
skinparam ParticipantBorderColor #999999
skinparam SequenceArrowColor #333333

participant "Flutter App" as app
participant "Internal\nWebView" as wv
participant "Google/GitHub\nOAuth" as oauth
participant "Backend\nCallback" as backend

app -> wv : Open login
wv -> oauth : OAuth redirect
oauth --> backend : Authorization code
backend -> backend : Generate JWT
backend --> wv : Redirect to\nnotesapp://auth/callback\n?token=JWT&refresh=REFRESH
wv --> app : Intercept deep link
app -> app : Save token in\nsecure storage

@enduml
