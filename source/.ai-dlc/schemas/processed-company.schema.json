{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adlc.local/schemas/processed-company.schema.json",
  "type": "object",
  "required": ["version", "generated_at", "documents"],
  "properties": {
    "version": { "type": "string" },
    "generated_at": { "type": "string" },
    "project_root": { "type": "string" },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "status", "message"],
        "properties": {
          "source": { "type": "string", "minLength": 1 },
          "output": { "type": ["string", "null"] },
          "status": { "type": "string", "enum": ["processed", "skipped", "failed", "unsupported"] },
          "tool": { "type": ["string", "null"] },
          "message": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
