{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adlc.local/schemas/halt-triggers.schema.json",
  "type": "object",
  "required": ["version", "triggers"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "patterns", "reason", "risk"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
          "patterns": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "reason": { "type": "string", "minLength": 1 },
          "risk": {
            "type": "string",
            "enum": ["LOW", "MEDIUM", "HIGH", "HIGH+", "CRITICAL"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
